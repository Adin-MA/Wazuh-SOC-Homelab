-D
-b 8192
--backlog_wait_time 60000
-f 1

-w /etc/passwd -p wa -k chck_passwd
-w /etc/shadow -p wa -k chck_shadow
-w /etc/group -p wa -k chck_group
-w /etc/sudoers -p wa -k chck_sudoers
-w /etc/sudoers.d -p wa -k chck_sudoers
-a always,exit -F arch=b64 -S chmod,fchmod,chown,fchown,lchown,fchmodat -F auid>=1000 -F auid!=-1 -F key=chck_chmod
