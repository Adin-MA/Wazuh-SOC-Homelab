<group name="authentication,bruteforce">

  <rule id="100100" level="13" frequency="7" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected (L1)</description>
  </rule>

  <rule id="100101" level="14" frequency="2" timeframe="3600">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected (L2)</description>
  </rule>

  <rule id="100102" level="15" frequency="2" timeframe="43200">
    <if_matched_sid>100101</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected (L3)</description>
  </rule>
  
</group>

<group name="monitoring,root">
  
  <rule id="100200" level="12">
    <if_sid>5402</if_sid>
    <location>journald</location>
    <match>COMMAND=/usr/bin/su</match>
    <description>Suspicious ROOT Activity Detected</description>
  </rule>
  
  <rule id="100201" level="12">
    <if_sid>5402</if_sid>
    <location>journald</location>
    <match>COMMAND=/usr/bin/sh</match>
    <description>Suspicious ROOT Activity Detected</description>
  </rule>

  <rule id="100202" level="12">
    <if_sid>5402</if_sid>
    <location>journald</location>
    <match>COMMAND=/usr/bin/bash</match>
    <description>Suspicious ROOT Activity Detected</description>
  </rule>

</group>

<group name="monitoring,audit">

  <rule id="100300" level="11">
    <if_sid>80700</if_sid>
    <field name="audit.key">chck_passwd</field>
    <field name="audit.syscall">257</field>
    <description>Someone Has Modified /etc/passwd</description>
  </rule>

  <rule id="100301" level="11">
    <if_sid>80700</if_sid>
    <field name="audit.key">chck_shadow</field>
    <description>Someone Has Modified /etc/shadow</description>
  </rule>

  <rule id="100302" level="11">
    <if_sid>80700</if_sid>
    <field name="audit.key">chck_group</field>
    <description>Someone Has Modified /etc/group</description>
  </rule>

  <rule id="100303" level="11">
    <if_sid>80700</if_sid>
    <field name="audit.key">chck_sudoers</field>
    <description>Someone Has Modified /etc/sudoers</description>
  </rule>

  <rule id="100304" level="11">
    <if_sid>80700</if_sid>
    <field name="audit.key">chck_chmod</field>
    <description>Someone Has Modified Permission</description>
  </rule>

  <rule id="100390" level="0">
    <if_sid>80730</if_sid>
    <match>operation="profile_replace"</match>
    <description>Mute AppArmor profile updates from Ubuntu Pro background jobs</description>
  </rule>

  <rule id="100391" level="0">
    <if_sid>80730</if_sid>
    <field name="audit.command">who</field>
    <match>denied_mask="r"</match>
    <description>Mute noisy localized AppArmor denials for 'who' command</description>
  </rule>

</group>

